DATABASE_URL=sqlite:///./dev.db
AUTH_SECRET=replace-with-a-long-random-secret
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DEFAULT_CARRIER=sf
SHIPPER_NAME=发货仓
SHIPPER_PHONE=13800000000
SHIPPER_ADDRESS=上海市浦东新区发货仓地址

# SF Express Open API / 丰桥标准接口
# 标准网关通常使用 partnerID/checkWord/serviceCode/msgData/msgDigest。
SF_PARTNER_ID=
SF_CHECK_WORD=
SF_GATEWAY_URL=https://sfapi.sf-express.com/std/service
SF_CREATE_SERVICE_CODE=EXP_RECE_CREATE_ORDER
SF_TRACK_SERVICE_CODE=EXP_RECE_SEARCH_ROUTES
SF_PAY_METHOD=1
SF_EXPRESS_TYPE_ID=1
# 如果企业给的是定制 JSON 网关，可使用下面这组 fallback。
SF_APP_ID=
SF_APP_SECRET=
SF_API_URL=
SF_TRACK_URL=
SF_WEBHOOK_SECRET=
SF_SIGN_ALGORITHM=hmac-sha256

# JD Logistics / 京东开放平台 JOS
JD_GATEWAY_URL=https://api.jd.com/routerjson
JD_CREATE_METHOD=
JD_TRACK_METHOD=
JD_ACCESS_TOKEN=
JD_SIGN_METHOD=md5
JD_VERSION=2.0
# 如果需要刷新 OAuth2 token，配置 token_url/refresh_token。
JD_APP_KEY=
JD_APP_SECRET=
JD_TOKEN_URL=
JD_REFRESH_TOKEN=
JD_API_URL=
JD_TRACK_URL=
JD_WEBHOOK_SECRET=

# Yimi Dida / LTL REST API
# 壹米滴答公开官网未暴露无需登录的开发文档时，按商务提供的 REST 网关方法名配置。
YIMI_GATEWAY_URL=
YIMI_CREATE_METHOD=
YIMI_TRACK_METHOD=
YIMI_APP_KEY=
YIMI_APP_SECRET=
YIMI_API_URL=
YIMI_TRACK_URL=
YIMI_WEBHOOK_SECRET=

CARRIER_TIMEOUT_SECONDS=8
CARRIER_RETRY_ATTEMPTS=3
CARRIER_RETRY_BACKOFF_SECONDS=0.8
